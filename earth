#!/usr/bin/env python3
"""A private, offline companion for chosen quests and reflection."""

import argparse
import os
import sqlite3
import sys
import tempfile
from datetime import timedelta
from pathlib import Path
from earth_core import (
    DRIVERS,
    PILLARS,
    EarthError,
    close_loop,
    complete_quest,
    create_loop,
    create_quest,
    data_path,
    database,
    drop_quest,
    exported_json,
    get_quest,
    initialize_database,
    now_utc,
    parse_timestamp,
    save_review,
    start_quest,
    update_character,
)

VERSION = "0.1.2"


def ask(label, default=None, option=None):
    suffix = f" [{default}]" if default else ""
    try:
        value = input(f"{label}{suffix}: ")
    except EOFError as error:
        hint = f"; pass {option}" if option else ""
        raise EarthError(f"missing {label.rstrip('?').lower()}{hint}") from error
    return default if not value and default is not None else value


def required(value, label, option):
    value = ask(label, option=option) if value is None else value
    if not value.strip():
        raise EarthError(f"{label.lower()} must not be empty; pass {option}")
    return value


def confirm(question):
    try:
        return input(f"{question} [y/N]: ").strip().lower() in ("y", "yes")
    except EOFError as error:
        raise EarthError("confirmation required; pass --yes") from error


def one_line(value):
    return " / ".join(value.splitlines())


def web_port(value):
    try:
        port = int(value)
    except ValueError as error:
        raise argparse.ArgumentTypeError("port must be a number") from error
    if not 0 <= port <= 65535:
        raise argparse.ArgumentTypeError("port must be between 0 and 65535")
    return port


def cmd_web(args):
    from earth_web import serve

    serve(args.port, open_browser=not args.no_open)


def cmd_init(_args):
    path, created = initialize_database()
    if created:
        print(f"Earth Game initialized at {path}")
    else:
        print(f"Earth Game is already initialized at {path}")


def cmd_character_show(_args):
    with database() as db:
        profile = db.execute("SELECT * FROM profile WHERE id = 1").fetchone()
    fields = (
        ("Values", "values_text"),
        ("Strengths", "strengths"),
        ("Frictions", "frictions"),
        ("Purpose", "purpose"),
        ("Anti-vision", "anti_vision"),
    )
    for label, field in fields:
        print(f"{label}: {profile[field] or '(not set)'}")


def cmd_character_edit(args):
    fields = (
        ("values_text", "Values", "--values"),
        ("strengths", "Strengths", "--strengths"),
        ("frictions", "Frictions", "--frictions"),
        ("purpose", "Purpose", "--purpose"),
        ("anti_vision", "Anti-vision", "--anti-vision"),
    )
    with database() as db:
        profile = db.execute("SELECT * FROM profile WHERE id = 1").fetchone()
        supplied = any(getattr(args, field) is not None for field, _, _ in fields)
        values = {
            field: getattr(args, field)
            for field, _, _ in fields
            if getattr(args, field) is not None
        }
        if not supplied:
            values = {
                field: ask(label, profile[field], option)
                for field, label, option in fields
            }
        update_character(db, values)
    print("Character updated.")


def cmd_quest_add(args):
    title = required(args.title, "Title", "--title")
    next_action = required(args.next_action, "Next action", "--next")
    with database() as db:
        quest_id = create_quest(
            db,
            title,
            next_action,
            args.why,
            args.pillar,
            args.driver,
            args.horizon,
        )
    print(f"Quest {quest_id} created.")


def cmd_quest_list(args):
    where = "" if args.all else "WHERE status IN ('current', 'planned')"
    with database() as db:
        quests = db.execute(
            f"""SELECT * FROM quests {where}
                ORDER BY status != 'current', id"""
        ).fetchall()
    if not quests:
        print(
            "No quests."
            if args.all
            else "No current or planned quests. Use --all for history."
        )
        return
    for quest in quests:
        tags = ", ".join(
            f"{label}={value}"
            for label, value in (
                ("pillar", quest["pillar"]),
                ("driver", quest["driver"]),
                ("horizon", quest["horizon"]),
            )
            if value
        )
        suffix = f" ({tags})" if tags else ""
        print(
            f"[{quest['id']}] {quest['status'].upper()} "
            f"{one_line(quest['title'])} — {one_line(quest['next_action'])}{suffix}"
        )


def cmd_quest_start(args):
    with database() as db:
        quest = get_quest(db, args.id)
        if quest["status"] not in ("planned", "current"):
            raise EarthError(f"quest {args.id} is {quest['status']}")
        if quest["status"] == "current":
            print(f"Quest {args.id} is already current.")
            return
        current = db.execute(
            "SELECT id, title FROM quests WHERE status = 'current'"
        ).fetchone()
        if (
            current
            and not args.yes
            and not confirm(
                f"Return current quest [{current['id']}] {one_line(current['title'])} to the backlog?"
            )
        ):
            raise EarthError("quest change cancelled")
        start_quest(db, args.id)
    print(f"Quest {args.id} is now current.")


def cmd_quest_done(args):
    with database() as db:
        if not complete_quest(db, args.id):
            print(f"Quest {args.id} is already completed.")
            return
    print(f"Quest {args.id} completed.")


def cmd_quest_drop(args):
    with database() as db:
        if not drop_quest(db, args.id):
            print(f"Quest {args.id} is already dropped.")
            return
    print(f"Quest {args.id} dropped.")


def cmd_loop_add(args):
    description = required(args.description, "Open loop", "--text")
    with database() as db:
        loop_id = create_loop(db, description)
    print(f"Open loop {loop_id} captured.")


def cmd_loop_list(args):
    where = "" if args.all else "WHERE status = 'open'"
    with database() as db:
        loops = db.execute(f"SELECT * FROM open_loops {where} ORDER BY id").fetchall()
    if not loops:
        print("No loops." if args.all else "No open loops. Use --all for history.")
        return
    for loop in loops:
        print(
            f"[{loop['id']}] {loop['status'].upper()} {one_line(loop['description'])}"
        )


def cmd_loop_close(args):
    with database() as db:
        if not close_loop(db, args.id):
            print(f"Open loop {args.id} is already closed.")
            return
    print(f"Open loop {args.id} closed.")


def cmd_review(args):
    questions = (
        (
            "love_connection",
            "Where did love or connection guide you?",
            args.love,
            "--love",
        ),
        (
            "adaptation",
            "What changed, and how did you adapt?",
            args.adaptation,
            "--adaptation",
        ),
        (
            "alignment",
            "Is the current quest authentic and aligned?",
            args.alignment,
            "--alignment",
        ),
        (
            "contribution",
            "What did you contribute?",
            args.contribution,
            "--contribution",
        ),
        (
            "next_action",
            "What next action or pillar now matters?",
            args.next_action,
            "--next",
        ),
    )
    with database() as db:
        loops = db.execute(
            "SELECT id, description FROM open_loops WHERE status = 'open' ORDER BY id"
        ).fetchall()
        if loops:
            print("Open loops:")
            for loop in loops:
                print(f"  [{loop['id']}] {one_line(loop['description'])}")
        else:
            print("Open loops: none")

        answers = {
            key: ask(question, option=option) if value is None else value
            for key, question, value, option in questions
        }
        update_quest = args.update_quest
        current = db.execute(
            "SELECT id FROM quests WHERE status = 'current'"
        ).fetchone()
        if current and not update_quest and sys.stdin.isatty():
            update_quest = confirm(
                "Use that answer as the current quest's next action?"
            )
        if update_quest:
            answers["next_action"] = required(
                answers["next_action"], "Next action", "--next"
            )
        save_review(db, answers, update_quest)
    print("Review saved.")


def cmd_export(args):
    with database() as db:
        output = exported_json(db)
    if not args.path:
        print(output, end="")
        return
    target = Path(args.path).expanduser()
    descriptor, temporary_name = tempfile.mkstemp(
        prefix=f".{target.name}.", dir=target.parent
    )
    temporary = Path(temporary_name)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as export_file:
            export_file.write(output)
        os.link(temporary, target)
    finally:
        temporary.unlink(missing_ok=True)
    print(f"Exported to {target}")


def cmd_today(_args):
    with database() as db:
        purpose = db.execute("SELECT purpose FROM profile WHERE id = 1").fetchone()[0]
        quest = db.execute(
            "SELECT id, title, next_action FROM quests WHERE status = 'current'"
        ).fetchone()
        planned_count = db.execute(
            "SELECT count(*) FROM quests WHERE status = 'planned'"
        ).fetchone()[0]
        loop_count = db.execute(
            "SELECT count(*) FROM open_loops WHERE status = 'open'"
        ).fetchone()[0]
        last_review = db.execute(
            "SELECT created_at FROM reviews ORDER BY id DESC LIMIT 1"
        ).fetchone()

    if purpose:
        print(f"Purpose: {purpose}")
    if quest:
        print(f"Current quest: [{quest['id']}] {quest['title']}")
        print(f"Next action: {quest['next_action']}")
    elif planned_count:
        print(
            f"No current quest. Choose from {planned_count} planned with "
            "'earth quest start ID'."
        )
    else:
        print("No current quest. Create one with 'earth quest add'.")
    print(f"Open loops: {loop_count}")

    last_review_at = parse_timestamp(last_review[0]) if last_review else None
    due = not last_review_at or now_utc() - last_review_at >= timedelta(days=7)
    print(
        "Review: due"
        if due
        else f"Review: last completed {last_review_at.astimezone().date().isoformat()}"
    )


def build_parser():
    path = data_path()
    parser = argparse.ArgumentParser(
        description="A private, offline companion for chosen quests and reflection.",
        epilog=(
            "Start: earth init; earth character edit; earth quest add; earth today\n\n"
            f"Data: {path}\n"
            "Backup: copy that database while earth is not running.\n"
            "Restore: replace it with a backup while earth is not running.\n"
            "Uninstall: remove this script; remove the data directory separately."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    commands = parser.add_subparsers(dest="command", metavar="COMMAND")
    parser.set_defaults(handler=lambda _args: parser.print_help())
    init = commands.add_parser(
        "init", help="create local storage", description="Create local storage."
    )
    init.set_defaults(handler=cmd_init)

    character = commands.add_parser(
        "character",
        help="show or edit the character",
        description="Show or edit values, strengths, frictions, purpose, and anti-vision.",
    )
    character_commands = character.add_subparsers(dest="action", metavar="ACTION")
    character.set_defaults(handler=lambda _args: character.print_help())
    character_show = character_commands.add_parser("show", help="show the profile")
    character_show.set_defaults(handler=cmd_character_show)
    character_edit = character_commands.add_parser("edit", help="edit the profile")
    character_edit.add_argument(
        "--values", dest="values_text", help="core values, as free text"
    )
    character_edit.add_argument("--strengths", help="natural or developed strengths")
    character_edit.add_argument(
        "--frictions", help="recurring obstacles or weak points"
    )
    character_edit.add_argument(
        "--purpose", help="the contribution or direction that matters"
    )
    character_edit.add_argument(
        "--anti-vision", dest="anti_vision", help="the future to actively avoid"
    )
    character_edit.set_defaults(handler=cmd_character_edit)

    quest = commands.add_parser(
        "quest",
        help="manage quests",
        description="Create and move quests through their lifecycle.",
    )
    quest_commands = quest.add_subparsers(dest="action", metavar="ACTION")
    quest.set_defaults(handler=lambda _args: quest.print_help())
    quest_add = quest_commands.add_parser("add", help="create a planned quest")
    quest_add.add_argument("--title", help="short quest title; prompted if omitted")
    quest_add.add_argument(
        "--next", dest="next_action", help="concrete next action; prompted if omitted"
    )
    quest_add.add_argument("--why", help="why this quest matters")
    quest_add.add_argument(
        "--pillar", choices=PILLARS, help="area of life this quest serves"
    )
    quest_add.add_argument(
        "--driver", choices=DRIVERS, help="motivation behind this quest"
    )
    quest_add.add_argument(
        "--horizon", help="free-form target horizon, such as 'this month'"
    )
    quest_add.set_defaults(handler=cmd_quest_add)
    quest_list = quest_commands.add_parser("list", help="list quests")
    quest_list.add_argument(
        "-a", "--all", action="store_true", help="include completed and dropped quests"
    )
    quest_list.set_defaults(handler=cmd_quest_list)
    quest_start = quest_commands.add_parser("start", help="make a quest current")
    quest_start.add_argument(
        "id", type=int, metavar="ID", help="quest ID from 'quest list'"
    )
    quest_start.add_argument(
        "-y",
        "--yes",
        action="store_true",
        help="replace the current quest without prompting",
    )
    quest_start.set_defaults(handler=cmd_quest_start)
    quest_done = quest_commands.add_parser("done", help="complete a quest")
    quest_done.add_argument(
        "id", type=int, metavar="ID", help="quest ID from 'quest list'"
    )
    quest_done.set_defaults(handler=cmd_quest_done)
    quest_drop = quest_commands.add_parser("drop", help="drop a quest")
    quest_drop.add_argument(
        "id", type=int, metavar="ID", help="quest ID from 'quest list'"
    )
    quest_drop.set_defaults(handler=cmd_quest_drop)

    loop = commands.add_parser(
        "loop",
        help="capture and close open loops",
        description="Capture unresolved obligations without changing the current quest.",
    )
    loop_commands = loop.add_subparsers(dest="action", metavar="ACTION")
    loop.set_defaults(handler=lambda _args: loop.print_help())
    loop_add = loop_commands.add_parser("add", help="capture an open loop")
    loop_add.add_argument(
        "--text", dest="description", help="open-loop text; prompted if omitted"
    )
    loop_add.set_defaults(handler=cmd_loop_add)
    loop_list = loop_commands.add_parser("list", help="list open loops")
    loop_list.add_argument(
        "-a", "--all", action="store_true", help="include closed loops"
    )
    loop_list.set_defaults(handler=cmd_loop_list)
    loop_close = loop_commands.add_parser("close", help="close an open loop")
    loop_close.add_argument(
        "id", type=int, metavar="ID", help="open-loop ID from 'loop list'"
    )
    loop_close.set_defaults(handler=cmd_loop_close)

    today = commands.add_parser("today", help="show the current focus")
    today.set_defaults(handler=cmd_today)

    review = commands.add_parser("review", help="record a weekly reflection")
    review.add_argument("--love", help="reflection on love and connection")
    review.add_argument("--adaptation", help="reflection on adapting to change")
    review.add_argument("--alignment", help="reflection on authenticity and alignment")
    review.add_argument("--contribution", help="reflection on contribution")
    review.add_argument(
        "--next", dest="next_action", help="next action or pillar needing attention"
    )
    review.add_argument(
        "--update-quest",
        action="store_true",
        help="use --next as the current quest's next action",
    )
    review.set_defaults(handler=cmd_review)

    export = commands.add_parser("export", help="export all data as JSON")
    export.add_argument(
        "path", nargs="?", metavar="PATH", help="new output file; omit to print JSON"
    )
    export.set_defaults(handler=cmd_export)

    web = commands.add_parser(
        "web",
        help="start the local web UI",
        description="Start a browser UI bound only to 127.0.0.1.",
    )
    web.add_argument(
        "--port",
        type=web_port,
        default=8765,
        metavar="PORT",
        help="local port (default: 8765)",
    )
    web.add_argument(
        "--no-open", action="store_true", help="do not open the browser automatically"
    )
    web.set_defaults(handler=cmd_web)
    return parser


def main():
    args = build_parser().parse_args()
    try:
        args.handler(args)
    except (EarthError, OSError, sqlite3.Error) as error:
        print(f"earth: {error}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
